{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caseworkbench.dev/schemas/FieldCatalog.schema.json",
  "title": "FieldCatalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["fields"],
  "properties": {
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "inferredType": {
            "type": "string",
            "enum": ["string", "number", "integer", "boolean", "date"]
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}